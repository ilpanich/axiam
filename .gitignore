# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
.idea/

# Codegraph
#  Codegraph generates a .codegraph directory in the root of the project to store its
#  internal data. This directory should be ignored to prevent it from being committed to version control.
.codegraph/

# CodeGraphContext
mcp.json
login-page.png
.playwright-mcp/

# Local dev secrets (JWT signing keys, TLS certs) — never commit
docker/.secrets/
**/*.pem
**/*.key

# Claude Code dev tooling — generated/ephemeral, reprovisioned by
# scripts/bootstrap-dev-tools.sh (GSD installs globally to ~/.claude).
.claude/
.claude-flow/
.mcp.json
CLAUDE.md.pre-ruflo
.swarm/

# buf-generated gRPC stubs — generate-on-build (D-01); run `cd sdks && buf generate`
# Each SDK build and CI regenerates these; they are never committed.
sdks/rust/src/gen/
sdks/typescript/src/gen/
sdks/go/gen/
sdks/python/axiam_sdk/gen/
sdks/java/src/main/java/io/axiam/sdk/gen/
