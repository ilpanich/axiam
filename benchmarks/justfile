# AXIAM benchmark commands. Run from the benchmarks/ directory: `just -f justfile <cmd>`
# or add `mod benchmarks` to the root justfile. Most commands take target= and profile=.
#
# NOTE: `just` only treats `name=value` as a variable override when it comes
# BEFORE the recipe name — placed after, it is parsed as another recipe to run
# (failing with "justfile does not contain recipe `target=…`"). So put the
# assignments first:
#
#   just target=axiam profile=p2-tls13 bench-up
#   just target=axiam bench-seed
#   just target=axiam profile=p2-tls13 bench-run
#   just bench-report
#   just targets="axiam keycloak" profiles="p0-plaintext p2-tls13 p3-mtls" bench-matrix

set shell := ["bash", "-uc"]

target := "axiam"
profile := "p0-plaintext"
scenario := "all"
sdk := "python"
targets := "axiam keycloak"
profiles := "p0-plaintext p2-tls13"
# build=1 forces a local source build of the AXIAM image; default (0) uses the
# published ghcr image (BENCH_AXIAM_IMAGE), falling back to a build if it can't
# be pulled. Competitors are always prebuilt images.
build := "0"
# rl selects the AXIAM rate-limit posture for the run:
#   neutralized (default) — limits raised to ~unlimited so k6's single source IP
#                           measures endpoint capacity, not the per-IP limiter.
#   prod                  — the server's production defaults (per-IP limiter
#                           ACTIVE). Head-to-head numbers taken this way are NOT
#                           comparable to competitors and report.py will flag them.
rl := "neutralized"
# dbcaps selects the datastore's CPU/mem envelope (C2):
#   capped (default) — the standard envelope, same as every other container
#                       (BENCH_DB_CPUS/BENCH_DB_MEM defaults in each target's
#                       docker-compose.yml, normally 2 CPUs / 1024 MiB).
#   uncapped          — raises the datastore to 4 CPUs / 2048 MiB so a run can
#                       show whether the datastore — not the server — is the
#                       ceiling. BENCH_DB_CPUS/BENCH_DB_MEM are already
#                       env-driven in every target's compose file; this just
#                       wires the two values through. An operator-supplied
#                       BENCH_DB_CPUS/BENCH_DB_MEM still wins over either mode.
dbcaps := "capped"
# repeat controls how many times `bench-matrix` runs the whole target×profile
# ×scenario matrix (C1: median-of-N). Each pass writes into its own
# results/run-<i>/ subtree (same flat per-cell layout underneath), and
# `bench-report`/`report.py` auto-detect the results/run-*/ layout and median
# every metric per cell across the valid runs. Set repeat=1 for a quick single
# pass (still lands under results/run-1/).
repeat := "3"

# Generate throwaway TLS/mTLS certs for the security profiles (idempotent).
bench-certs:
    bash runner/gen-certs.sh

# Bring a target up under a security profile (adds TLS edge for p1/p2/p3).
bench-up:
    #!/usr/bin/env bash
    set -euo pipefail
    source profiles/{{profile}}.env
    COMPOSE="targets/{{target}}/docker-compose.yml"

    # --- AXIAM target: secrets + image selection (competitors need neither) ---
    if [ "{{target}}" = "axiam" ]; then
      # User-provided secrets win if present (real deployment creds/keys).
      [ -f ../docker/.secrets/env ] && source ../docker/.secrets/env || true
      # Otherwise bootstrap STABLE, throwaway, local-only bench secrets so the
      # compose file's required vars resolve — mirrors `just prod-up`'s JWT keygen.
      # Stable (not random) so a persisted DB volume still authenticates on re-run.
      SECRETS_DIR="../docker/.secrets"
      PRIV="$SECRETS_DIR/jwt_ed25519.pem"; PUB="$SECRETS_DIR/jwt_ed25519.pub.pem"
      if [ ! -f "$PRIV" ] || [ ! -f "$PUB" ]; then
        command -v openssl >/dev/null || { echo "[bench-up] openssl is required to generate the JWT keypair"; exit 1; }
        echo "[bench-up] generating throwaway Ed25519 JWT keypair under docker/.secrets/ (first run)"
        mkdir -p "$SECRETS_DIR"
        openssl genpkey -algorithm ed25519 -out "$PRIV"
        openssl pkey -in "$PRIV" -pubout -out "$PUB"
        chmod 600 "$PRIV"
      fi
      export AXIAM__AUTH__JWT_PRIVATE_KEY_PEM="${AXIAM__AUTH__JWT_PRIVATE_KEY_PEM:-$(cat "$PRIV")}"
      export AXIAM__AUTH__JWT_PUBLIC_KEY_PEM="${AXIAM__AUTH__JWT_PUBLIC_KEY_PEM:-$(cat "$PUB")}"
      # Stable local hex-secret helper: generate once, reuse across runs so a
      # persisted DB volume and previously-encrypted data stay decryptable.
      genhex() { local f="$SECRETS_DIR/$1"; [ -f "$f" ] || { openssl rand -hex 32 > "$f"; chmod 600 "$f"; }; cat "$f"; }
      # AMQP master signing key (SECHRD-08 / D-05c) — mandatory at startup in the
      # release image (there is no unsigned code path).
      export AXIAM__AMQP__SIGNING_KEY="${AXIAM__AMQP__SIGNING_KEY:-$(genhex amqp_signing.hex)}"
      # Optional subsystem secrets — set so MFA, GDPR pseudonymization, email/GDPR
      # export, the password pepper, and OIDC discovery are all functional rather
      # than degraded-off (D-02 / REQ-14). The encryption keys/pepper are 64-hex
      # (32-byte AES-256-GCM / HMAC); AXIAM__AUTH__PEPPER is a plain string; the
      # OIDC issuer must be https or localhost.
      export AXIAM__AUTH__MFA_ENCRYPTION_KEY="${AXIAM__AUTH__MFA_ENCRYPTION_KEY:-$(genhex mfa_enc.hex)}"
      export AXIAM__EMAIL_ENCRYPTION_KEY="${AXIAM__EMAIL_ENCRYPTION_KEY:-$(genhex email_enc.hex)}"
      export AXIAM__GDPR_PSEUDONYM_PEPPER="${AXIAM__GDPR_PSEUDONYM_PEPPER:-$(genhex gdpr_pepper.hex)}"
      export AXIAM__AUTH__PEPPER="${AXIAM__AUTH__PEPPER:-$(genhex auth_pepper.hex)}"
      export AXIAM__AUTH__OAUTH2_ISSUER_URL="${AXIAM__AUTH__OAUTH2_ISSUER_URL:-${BENCH_ISSUER_URL:-http://localhost:${BENCH_APP_PORT:-8090}}}"
      export AXIAM__DB__USERNAME="${AXIAM__DB__USERNAME:-bench}"
      export AXIAM__DB__PASSWORD="${AXIAM__DB__PASSWORD:-bench-local-only-pw}"
      export RABBITMQ_DEFAULT_USER="${RABBITMQ_DEFAULT_USER:-bench}"
      export RABBITMQ_DEFAULT_PASS="${RABBITMQ_DEFAULT_PASS:-bench-local-only-pw}"
      # Rate-limit posture (see `rl` at the top of this file). Neutralized is the
      # default so a single-IP k6 run measures endpoint capacity. The prod values
      # mirror the server defaults in crates/axiam-api-rest/src/config/rate_limit.rs
      # and crates/axiam-api-grpc/src/config.rs — keep them in sync if those change.
      export AXIAM_BENCH_RL_POSTURE="{{rl}}"
      if [ "{{rl}}" = "prod" ]; then
        echo "[bench-up] rate limits: PRODUCTION posture — per-IP limiter ACTIVE (head-to-head numbers will be throttled and flagged by report.py)"
        export AXIAM__RATE_LIMIT__LOGIN_PER_MIN=10
        export AXIAM__RATE_LIMIT__REGISTER_PER_MIN=5
        export AXIAM__RATE_LIMIT__TOKEN_PER_MIN=20
        export AXIAM__RATE_LIMIT__PASSWORD_RESET_PER_MIN=3
        export AXIAM__RATE_LIMIT__MFA_PER_MIN=5
        export AXIAM__RATE_LIMIT__INTROSPECT_PER_MIN=10
        export AXIAM__RATE_LIMIT__REVOKE_PER_MIN=10
        export AXIAM__RATE_LIMIT__AUTHZ_CHECK_PER_MIN=300
        export AXIAM__GRPC__GRPC_AUTHZ_PER_SEC=100
      elif [ "{{rl}}" != "neutralized" ]; then
        echo "[bench-up] unknown rl='{{rl}}' (use rl=neutralized or rl=prod)" >&2; exit 1
      else
        echo "[bench-up] rate limits: NEUTRALIZED (compose defaults ~unlimited)"
      fi
      # Default the prebuilt image tag to the workspace version so it tracks
      # releases automatically (override with BENCH_AXIAM_IMAGE).
      if [ -z "${BENCH_AXIAM_IMAGE:-}" ]; then
        VER="$(grep -m1 '^version' ../Cargo.toml | cut -d'"' -f2)"
        export BENCH_AXIAM_IMAGE="ghcr.io/ilpanich/axiam/server:${VER}"
      fi
    fi

    # DB CPU/mem envelope (C2, all targets — see `dbcaps` at the top of this
    # file). BENCH_DB_CPUS/BENCH_DB_MEM are already read directly by every
    # target's docker-compose.yml (surrealdb/postgres `cpus:`/`mem_limit:`),
    # so this only needs to set the two env vars before `docker compose up`;
    # an operator-supplied BENCH_DB_CPUS/BENCH_DB_MEM still wins. The chosen
    # values are recorded in meta.json automatically — run-benchmark.sh reads
    # each container's actual cpu/mem cap straight off `docker inspect`
    # (HostConfig.NanoCpus/Memory) rather than trusting this shell's env, so a
    # separate `bench-run` invocation still captures whatever cap the running
    # DB container was actually started with.
    if [ "{{dbcaps}}" = "uncapped" ]; then
      export BENCH_DB_CPUS="${BENCH_DB_CPUS:-4}"
      export BENCH_DB_MEM="${BENCH_DB_MEM:-2048m}"
      echo "[bench-up] DB caps: UNCAPPED (${BENCH_DB_CPUS} CPUs / ${BENCH_DB_MEM}) — measuring the server ceiling, not the datastore's"
    elif [ "{{dbcaps}}" != "capped" ]; then
      echo "[bench-up] unknown dbcaps='{{dbcaps}}' (use dbcaps=capped or dbcaps=uncapped)" >&2; exit 1
    fi

    PROFILE_ARG=""
    OVERRIDE_ARG=""
    if [ "{{profile}}" != "p0-plaintext" ]; then
      # Both targets need the throwaway server/CA certs for TLS profiles: AXIAM
      # fronts them with an nginx edge, Keycloak terminates TLS in-process from
      # the same /certs mount. (mkcert-style material; profiles/certs is gitignored.)
      just bench-certs
    fi
    if [ "{{profile}}" != "p0-plaintext" ] && [ "{{target}}" = "axiam" ]; then
      if [ "{{profile}}" = "p2-tls13" ] && [ -n "${BENCH_NGINX_CONF:-}" ]; then
        # B2 isolation cell: an operator-set BENCH_NGINX_CONF (tls13-h1.conf)
        # forces the nginx-fronted p2 path instead of the native rustls
        # listener, giving a TLS 1.3 + HTTP/1.1-only edge to isolate the
        # h2-vs-h1.1 effect. See targets/axiam/tls/tls13-h1.conf. Invoke as:
        #   BENCH_NGINX_CONF=tls13-h1.conf just target=axiam profile=p2-tls13 bench-up
        PROFILE_ARG="--profile tls"
      elif [ "{{profile}}" = "p2-tls13" ]; then
        # p2 = TLS 1.3, server-auth: exactly what AXIAM's native rustls listener
        # does, so terminate in-process (no nginx) to measure AXIAM's own TLS
        # stack inside its CPU cap — comparable to keycloak/zitadel native TLS.
        # See targets/axiam/docker-compose.native-tls.yml.
        OVERRIDE_ARG="-f targets/axiam/docker-compose.native-tls.yml"
      elif [ "{{profile}}" = "p3-mtls" ]; then
        # p3 = TLS 1.3 + X.509 client-cert auth. AXIAM now verifies client certs
        # in-process (D3: rustls WebPkiClientVerifier over profiles/certs/ca.crt),
        # so terminate mTLS natively — no nginx edge — making the VERIFIED peer
        # cert the identity source (not a proxy header) and keeping the crypto
        # inside AXIAM's cap. Layers the mTLS overlay on top of the native-TLS
        # one (same pattern p2 used in 649798e).
        OVERRIDE_ARG="-f targets/axiam/docker-compose.native-tls.yml -f targets/axiam/docker-compose.native-mtls.yml"
      else
        # p1-tls12: the native stack is TLS 1.3-only by policy and can't do
        # TLS 1.2, so keep the nginx edge for that profile (see docs/security-profiles.md).
        case "{{profile}}" in
          p1-tls12) export BENCH_NGINX_CONF=tls12.conf ;;
        esac
        PROFILE_ARG="--profile tls"
      fi
    fi
    # Zitadel terminates TLS in-process (tlsMode=enabled) for the https profiles,
    # serving HTTPS+h2 on its port with the shared throwaway cert. TLS 1.2-vs-1.3
    # and mTLS are not separately tunable in Zitadel's built-in listener, so p1/p2
    # both use its default modern TLS; p3-mtls has no client-cert story here.
    if [ "{{profile}}" != "p0-plaintext" ] && [ "{{target}}" = "zitadel" ]; then
      export BENCH_ZITADEL_TLS_MODE=enabled
      export BENCH_ZITADEL_EXTERNAL_SECURE=true
      export BENCH_ZITADEL_TLS_ENABLED=true
      export BENCH_ZITADEL_TLS_CERTPATH=/certs/server.crt
      export BENCH_ZITADEL_TLS_KEYPATH=/certs/server.key
      if [ "{{profile}}" = "p3-mtls" ]; then
        echo "[bench-up] NOTE: Zitadel's built-in TLS has no mTLS/client-cert mode;" >&2
        echo "           running p3 as server-TLS only for zitadel." >&2
      fi
    fi

    BUILD_ARG=""
    if [ "{{build}}" = "1" ] && [ "{{target}}" = "axiam" ]; then
      BUILD_ARG="--build"          # force a local source build of the AXIAM image
    elif [ "{{target}}" = "axiam" ]; then
      # Default: fetch the prebuilt server image so no source build is needed.
      if ! docker compose -f "$COMPOSE" pull axiam-server 2>/dev/null; then
        echo "[bench-up] could not pull $BENCH_AXIAM_IMAGE."
        echo "           GHCR packages are private by default and per-tag images may not"
        echo "           be published, so an unauthenticated pull is denied. To use the"
        echo "           prebuilt image: 'docker login ghcr.io' with a PAT that can read"
        echo "           the package, or set BENCH_AXIAM_IMAGE to an image you can pull."
        echo "           Falling back to a local source build now (same as build=1)."
        BUILD_ARG="--build"
      fi
    fi

    # --- Port pre-flight -------------------------------------------------------
    # Fail fast with an actionable message if a host port we're about to publish
    # is already taken — otherwise docker dies with a cryptic "bind: address
    # already in use" (or, for a port docker doesn't publish, the readiness gate
    # just times out after 180s). Common culprit: a dev service (e.g. sage-gui)
    # holding 8443, the default BENCH_TLS_PORT.
    check_port() {
      if timeout 2 bash -c "exec 3<>/dev/tcp/127.0.0.1/$1" 2>/dev/null; then
        echo "[bench-up] port $1 ($2) is already in use on 127.0.0.1." >&2
        echo "           Free it, or override the port, e.g.:" >&2
        echo "             BENCH_TLS_PORT=18443 just target={{target}} profile={{profile}} bench-up" >&2
        return 1
      fi
    }
    port_conflict=0
    if [ "{{target}}" = "axiam" ] && [ -n "$OVERRIDE_ARG" ]; then
      # Native TLS/mTLS (p2-tls13, p3-mtls): the server publishes the TLS port
      # (+ grpc); no plaintext 8090. Detected via the native compose override.
      check_port "${BENCH_TLS_PORT:-8443}" "TLS / BENCH_TLS_PORT" || port_conflict=1
    else
      check_port "${BENCH_APP_PORT:-8090}" "app / BENCH_APP_PORT" || port_conflict=1
      # Targets that also publish the TLS port: keycloak always; axiam with its edge.
      if [ "{{target}}" = "keycloak" ] || { [ "{{target}}" = "axiam" ] && [ -n "$PROFILE_ARG" ]; }; then
        check_port "${BENCH_TLS_PORT:-8443}" "TLS / BENCH_TLS_PORT" || port_conflict=1
      fi
    fi
    [ "$port_conflict" -eq 0 ] || exit 1

    docker compose -f "$COMPOSE" $OVERRIDE_ARG $PROFILE_ARG up -d --wait $BUILD_ARG

    # --- Readiness gate --------------------------------------------------------
    # `up -d --wait` only blocks until each container is *running* (or, if it has
    # one, healthcheck-healthy). The zitadel/keycloak services declare no app-level
    # healthcheck, so --wait returns while the server is still running migrations /
    # `start-from-init`. The published port is already bound by docker-proxy, so a
    # too-early request is ACCEPTED and then RST — surfacing to k6 as
    # "connection reset by peer" on e.g. GET /oauth/v2/keys a couple of seconds in.
    # Gate on the target's real HTTP readiness at the EXACT scheme/host/port k6 will
    # hit (BENCH_SCHEME/BENCH_PORT come from the profile env sourced above), so
    # neither seeding nor the k6 run can start against a not-yet-serving target.
    READY_HOST="${BENCH_HOST:-localhost}"
    READY_PORT="${BENCH_PORT:-${BENCH_APP_PORT:-8090}}"
    READY_BASE="${BENCH_SCHEME:-http}://${READY_HOST}:${READY_PORT}"
    case "{{target}}" in
      zitadel)  READY_URL="$READY_BASE/debug/ready" ;;    # 200 only when fully initialized
      keycloak) READY_URL="$READY_BASE/realms/master" ;;  # 200 once the server serves
      *)        READY_URL="$READY_BASE/health" ;;         # axiam liveness/readiness
    esac
    echo "[bench-up] waiting for {{target}} to serve at $READY_URL (timeout 180s)"
    ready_deadline=$(( $(date +%s) + 180 ))
    # Native mTLS (axiam p3-mtls, client_auth=required): the listener rejects any
    # connection without a verified client cert, so the readiness probe must
    # present one too. BENCH_CLIENT_CERT/KEY come from the sourced profile env.
    READY_MTLS=""
    if [ "{{target}}" = "axiam" ] && [ "{{profile}}" = "p3-mtls" ] \
       && [ -n "${BENCH_CLIENT_CERT:-}" ] && [ -n "${BENCH_CLIENT_KEY:-}" ]; then
      READY_MTLS="--cert ${BENCH_CLIENT_CERT} --key ${BENCH_CLIENT_KEY}"
    fi
    # -k: the TLS profiles front a throwaway private CA k6 also can't verify.
    until curl -skf $READY_MTLS -o /dev/null "$READY_URL"; do
      if [ "$(date +%s)" -ge "$ready_deadline" ]; then
        echo "[bench-up] TIMEOUT: {{target}} did not become ready at $READY_URL" >&2
        docker compose -f "$COMPOSE" $PROFILE_ARG ps >&2 || true
        docker compose -f "$COMPOSE" $PROFILE_ARG logs --tail 40 >&2 || true
        exit 1
      fi
      sleep 2
    done
    echo "[bench-up] {{target}} is ready."

# Provision org/tenant/user/client for a target; writes .seed/<target>.seed.env
# (client secrets/passwords — gitignored, kept out of the results/ tree we
# share) and, once the post-seed smoke checks pass, results/<target>.seed.ok
# (a no-secret marker bench-run refuses to start the k6 matrix without).
# Seeding talks to the plaintext app port (:8090) for AXIAM/Keycloak, which keep
# HTTP alongside HTTPS. Zitadel under a TLS profile serves TLS-only, so its seed
# must go over https:<tls-port> — derived from the profile env here and passed as
# the base URL (seed.sh uses curl -k for Zitadel, trusting the throwaway CA).
bench-seed:
    #!/usr/bin/env bash
    set -euo pipefail
    if { [ "{{target}}" = "zitadel" ] && [ "{{profile}}" != "p0-plaintext" ]; } \
       || { [ "{{target}}" = "axiam" ] && { [ "{{profile}}" = "p2-tls13" ] || [ "{{profile}}" = "p3-mtls" ]; }; }; then
      # TLS-only listeners (zitadel built-in TLS; axiam native rustls) have no
      # plaintext side port, so seed over https at the TLS port (seed.sh uses -k).
      # For axiam p3-mtls the native listener also REQUIRES a client cert, so
      # sourcing the profile env exports BENCH_CLIENT_CERT/KEY, which seed.sh
      # presents transparently on every request (see its curl wrapper).
      source profiles/{{profile}}.env
      BASE="${BENCH_SCHEME:-https}://${BENCH_HOST:-localhost}:${BENCH_PORT:-8443}"
      bash runner/seed.sh {{target}} "$BASE"
    else
      bash runner/seed.sh {{target}}
    fi

# Run the scenario suite (load + resource sampling) for a target/profile.
bench-run:
    bash runner/run-benchmark.sh --target {{target}} --profile {{profile}} --scenario {{scenario}}

# Tear a target down (and its volumes).
bench-down:
    #!/usr/bin/env bash
    set -euo pipefail
    # `docker compose down` interpolates the ENTIRE compose file, so the AXIAM
    # target's required (:?) secret vars must still resolve — even though teardown
    # never uses them. Provide harmless placeholders so down never needs the real
    # secrets (competitors ignore these).
    export AXIAM__DB__USERNAME=x AXIAM__DB__PASSWORD=x \
           RABBITMQ_DEFAULT_USER=x RABBITMQ_DEFAULT_PASS=x \
           AXIAM__AUTH__JWT_PRIVATE_KEY_PEM=x AXIAM__AUTH__JWT_PUBLIC_KEY_PEM=x \
           AXIAM__AMQP__SIGNING_KEY=x AXIAM__AUTH__MFA_ENCRYPTION_KEY=x \
           AXIAM__EMAIL_ENCRYPTION_KEY=x AXIAM__GDPR_PSEUDONYM_PEPPER=x
    COMPOSE="targets/{{target}}/docker-compose.yml"
    docker compose -f "$COMPOSE" --profile tls down -v || \
      docker compose -f "$COMPOSE" down -v

# Aggregate everything under results/ into results/report.md.
bench-report:
    python3 runner/report.py --results results

# Full unattended matrix: every target × profile × scenario, with up/seed/run/down.
# repeat=N (default 3, see `repeat` above): runs the whole matrix N times,
# each pass writing into its own results/run-<i>/ subtree using the SAME flat
# target/profile/scenario layout underneath, so the existing per-cell code
# (seed marker, run-benchmark.sh) is reused unchanged. report.py auto-detects
# the results/run-*/ layout and medians each cell across the valid runs (C1).
# `rl` and `dbcaps` are forwarded to every bench-up so
# `just target=axiam rl=prod bench-matrix` / `just dbcaps=uncapped bench-matrix`
# work end-to-end (not just for a single manual bench-up).
bench-matrix:
    #!/usr/bin/env bash
    set -euo pipefail
    for i in $(seq 1 {{repeat}}); do
      RUN_DIR="results/run-$i"
      echo "### repeat $i/{{repeat}} -> $RUN_DIR ###"
      mkdir -p "$RUN_DIR"
      export BENCH_RESULTS_DIR="$PWD/$RUN_DIR"
      for t in {{targets}}; do
        for p in {{profiles}}; do
          echo "=== run $i: $t / $p (rl={{rl}} dbcaps={{dbcaps}}) ==="
          just target=$t profile=$p rl={{rl}} dbcaps={{dbcaps}} build={{build}} bench-up
          just target=$t profile=$p bench-seed
          just target=$t profile=$p bench-run
          just target=$t bench-down
        done
      done
    done
    unset BENCH_RESULTS_DIR
    just bench-report

# --- SDK client benchmarks --- (pass the language as sdk=, e.g. sdk=python)
sdk-bench:
    bash sdk/{{sdk}}/run.sh

sdk-bench-all:
    bash sdk/run-all.sh
    python3 sdk/collect.py --results results

# Remove all run artifacts (keeps the dir).
bench-clean:
    find results -type f ! -name '.gitkeep' -delete || true

# Package shareable results into results-<date>.tar.xz. Only k6 summaries,
# resource/host CSVs, run metadata, and the generated report are included —
# NOT .seed/ (client secrets, bench user password), which report.py and this
# recipe never read from and which `git` never sees (see .gitignore / A7 in
# claude_dev/benchmark-improvement-plan.md). Verifies the archive is clean
# before leaving it on disk.
bench-pack:
    #!/usr/bin/env bash
    set -euo pipefail
    OUT="results-$(date +%Y-%m-%d).tar.xz"
    FILELIST="$(mktemp)"
    trap 'rm -f "$FILELIST"' EXIT
    find results \( -name '*.k6.json' -o -name '*.res.csv' -o -name '*.host.csv' \
      -o -name '*.meta.json' -o -name 'report.md' \) -type f > "$FILELIST"
    if [ ! -s "$FILELIST" ]; then
      echo "[bench-pack] nothing to pack — run a benchmark + 'just bench-report' first" >&2
      exit 1
    fi
    tar -cJf "$OUT" -T "$FILELIST"
    echo "[bench-pack] wrote $OUT ($(wc -l < "$FILELIST") files)"
    echo "[bench-pack] verifying no secret material leaked in..."
    if tar -tJf "$OUT" | grep -qiE '\.seed/|seed\.env'; then
      echo "[bench-pack] ERROR: a .seed/ path made it into the archive" >&2; exit 1
    fi
    if tar -xJOf "$OUT" | grep -qiE 'SECRET|PASSWORD'; then
      echo "[bench-pack] ERROR: SECRET/PASSWORD text found in packed content — investigate before sharing" >&2
      exit 1
    fi
    echo "[bench-pack] OK — $OUT contains no secret material."
