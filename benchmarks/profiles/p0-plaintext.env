# Security profile p0: plaintext HTTP. Speed ceiling / baseline.
export BENCH_PROFILE=p0-plaintext
export BENCH_SCHEME=http
export BENCH_TLS_MIN=
export BENCH_TLS_CIPHERS=
export BENCH_CLIENT_CERT=
export BENCH_CLIENT_KEY=
export BENCH_CA_CERT=
export BENCH_VERIFY_TLS=false
# Default app port (no TLS terminator in front).
export BENCH_PORT=${BENCH_PORT:-8090}
