# Security profile p1: TLS 1.2 with a broad cipher set, server-auth only.
export BENCH_PROFILE=p1-tls12
export BENCH_SCHEME=https
export BENCH_TLS_MIN=1.2
# Broad, still-acceptable TLS 1.2 suites (no RC4/3DES/CBC-SHA1).
export BENCH_TLS_CIPHERS="ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384"
export BENCH_CLIENT_CERT=
export BENCH_CLIENT_KEY=
export BENCH_CA_CERT=${BENCH_CERTS_DIR:-profiles/certs}/ca.crt
export BENCH_VERIFY_TLS=true
# HTTPS edge port fronting the resource-capped server.
export BENCH_PORT=${BENCH_TLS_PORT:-8443}
