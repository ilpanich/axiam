# Security profile p3: mutual TLS + X.509 client-cert auth on TLS 1.3.
# Strictest posture; exercises certificate-based authentication (IoT/mTLS).
export BENCH_PROFILE=p3-mtls
export BENCH_SCHEME=https
export BENCH_TLS_MIN=1.3
export BENCH_TLS_CIPHERS="TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256"
# k6 presents this client certificate; the server requires + verifies it.
export BENCH_CLIENT_CERT=${BENCH_CERTS_DIR:-profiles/certs}/client.crt
export BENCH_CLIENT_KEY=${BENCH_CERTS_DIR:-profiles/certs}/client.key
export BENCH_CA_CERT=${BENCH_CERTS_DIR:-profiles/certs}/ca.crt
export BENCH_VERIFY_TLS=true
export BENCH_PORT=${BENCH_TLS_PORT:-8443}
# Signals the target compose to require client certs (mTLS).
export BENCH_REQUIRE_CLIENT_CERT=true
